{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SPECTER",
  "description": "Post-quantum stealth addresses for private payments on Ethereum and Sui",
  "colors": {
    "primary": "#0F766E",
    "light": "#14B8A6",
    "dark": "#115E59"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/images/specter/logo.png",
    "dark": "/images/specter/logo.png"
  },
  "styling": {
    "eyebrows": "section",
    "codeblocks": {
      "rounded": true
    },
    "anchors": {
      "icon": {
        "rounded": true
      }
    }
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true,
    "raiseIssue": true
  },
  "search": {
    "prompt": "Search SPECTER docs..."
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Welcome",
            "pages": [
              "index",
              "why-specter/the-problem",
              "why-specter/how-specter-works",
              "why-specter/specter-vs-others"
            ]
          },
          {
            "group": "Understand the tech",
            "pages": [
              "how-it-works/protocol-flow",
              "how-it-works/post-quantum-crypto",
              "how-it-works/view-tags-and-scanning",
              "how-it-works/security-boundaries",
              "how-it-works/architecture"
            ]
          },
          {
            "group": "Try it",
            "pages": [
              "explore/playground",
              "getting-started/quickstart",
              "getting-started/installation"
            ]
          },
          {
            "group": "Use cases",
            "pages": [
              "use-cases/private-payments",
              "use-cases/yellow-private-channels",
              "use-cases/name-services",
              "use-cases/whats-next"
            ]
          },
          {
            "group": "Deep dive",
            "pages": [
              "deep-dive/post-quantum-explainer",
              "deep-dive/erc-proposal",
              "deep-dive/research-notes",
              "deep-dive/terminology"
            ]
          },
          {
            "group": "Build with SPECTER",
            "pages": [
              "build/integration-guide",
              "build/development-setup",
              "build/contributing"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "faq",
              "reference/changelog",
              "roadmap/yet-to-implement"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api/introduction",
              "api/auth-and-errors"
            ]
          },
          {
            "group": "Core endpoints",
            "pages": [
              "api/keys",
              "api/stealth",
              "api/nameservice",
              "api/ipfs",
              "api/registry"
            ]
          },
          {
            "group": "Yellow endpoints",
            "pages": [
              "api/yellow"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Launch App",
          "href": "https://specterpq.com/",
          "icon": "rocket"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/pranshurastogi/SPECTER",
          "icon": "github"
        },
        {
          "anchor": "Live API",
          "href": "https://backend.specterpq.com/health",
          "icon": "server"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://specterpq.com/"
      },
      {
        "label": "GitHub",
        "href": "https://github.com/pranshurastogi/SPECTER"
      },
      {
        "label": "Research Paper",
        "href": "https://arxiv.org/pdf/2501.13733v1"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Launch App",
      "href": "https://specterpq.com/"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/pranshurastogi/SPECTER",
      "x": "https://x.com/specter_PQ"
    }
  }
}
